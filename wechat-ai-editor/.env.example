# ===========================================
# 微信公众号 AI 编辑器 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填写配置

# --- LLM API 配置 ---
# 已有 LLM 服务器地址 (阿里云 8.145.39.17)
LLM_API_BASE=http://8.145.39.17:8080/v1
# LLM API 密钥 (如有)
LLM_API_KEY=
# 模型名称
LLM_MODEL_NAME=glm-5.1-w8a8

# --- 微信公众平台配置 ---
# 在 https://mp.weixin.qq.com 后台 "开发 -> 基本配置" 获取
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_app_secret

# --- CORS 配置 ---
# 允许跨域的前端域名，多个用逗号分隔
CORS_ORIGINS=https://wechat-ai-editor-hjh.vercel.app

# --- 可选配置 (有默认值) ---
# SQLITE_DB_PATH=./data/wechat_editor.db
# ASSETS_DIR=./assets
# UPLOAD_DIR=./uploads
# MAX_IMAGES_PER_ARTICLE=10
